{
    "name": "acefolio/laravel-shopify",
    "description": "A comprehensive Laravel package replicating Shopify CLI core functionality with App Bridge 4 and Token Exchange support.",
    "keywords": ["laravel", "shopify", "shopify-app", "app-bridge", "token-exchange"],
    "license": "MIT",
    "authors": [
        {
            "name": "Muhammad Atif",
            "email": "contact@acefolio.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.5",
        "firebase/php-jwt": "^6.8",
        "lcobucci/jwt": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelShopify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelShopify\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelShopify\\ShopifyAppServiceProvider"
            ],
            "aliases": {
                "ShopifyApp": "LaravelShopify\\Facades\\ShopifyApp"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
